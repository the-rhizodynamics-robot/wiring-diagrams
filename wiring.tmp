graph {
// Graph generated by WireViz 0.4.1
// https://github.com/wireviz/WireViz
	graph [bgcolor="#FFFFFF" fontname=arial nodesep=0.33 rankdir=LR ranksep=2]
	node [fillcolor="#FFFFFF" fontname=arial height=0 margin=0 shape=none style=filled width=0]
	edge [fontname=arial style=bold]
	MEGA [label=<
<table border="0" cellspacing="0" cellpadding="0">
 <tr><td>
  <table border="0" cellspacing="0" cellpadding="3" cellborder="1"><tr>
   <td balign="left">MEGA</td>
  </tr></table>
 </td></tr>
 <tr><td>
  <table border="0" cellspacing="0" cellpadding="3" cellborder="1"><tr>
   <td balign="left">Arduino Mega 2560</td>
   <td balign="left">17-pin</td>
  </tr></table>
 </td></tr>
 <tr><td>
  <table border="0" cellspacing="0" cellpadding="3" cellborder="1">
   <tr>
    <td>D5</td>
    <td port="p1r">1</td>
   </tr>
   <tr>
    <td>D7</td>
    <td port="p2r">2</td>
   </tr>
   <tr>
    <td>D6</td>
    <td port="p3r">3</td>
   </tr>
   <tr>
    <td>D8</td>
    <td port="p4r">4</td>
   </tr>
   <tr>
    <td>D10</td>
    <td port="p5r">5</td>
   </tr>
   <tr>
    <td>D9</td>
    <td port="p6r">6</td>
   </tr>
   <tr>
    <td>D3</td>
    <td port="p7r">7</td>
   </tr>
   <tr>
    <td>D2</td>
    <td port="p8r">8</td>
   </tr>
   <tr>
    <td>D12</td>
    <td port="p9r">9</td>
   </tr>
   <tr>
    <td>D23</td>
    <td port="p10r">10</td>
   </tr>
   <tr>
    <td>D25</td>
    <td port="p11r">11</td>
   </tr>
   <tr>
    <td>D27</td>
    <td port="p12r">12</td>
   </tr>
   <tr>
    <td>D29</td>
    <td port="p13r">13</td>
   </tr>
   <tr>
    <td>D31</td>
    <td port="p14r">14</td>
   </tr>
   <tr>
    <td>D33</td>
    <td port="p15r">15</td>
   </tr>
   <tr>
    <td>5V</td>
    <td port="p16r">16</td>
   </tr>
   <tr>
    <td>GND</td>
    <td port="p17r">17</td>
   </tr>
  </table>
 </td></tr>
 <tr><td>
  <table border="0" cellspacing="0" cellpadding="3" cellborder="1"><tr>
   <td balign="left">Powered from the host PC over USB; its 5 V pin feeds the photointerrupters and the relay board (logic + coil). The Mega never touches the 24 V bus — the logic and 24 V power grounds are separate domains, bridged only by the drivers' input optocouplers.</td>
  </tr></table>
 </td></tr>
</table>
> fillcolor="#FFFFFF" shape=box style=filled]
	XDRV [label=<
<table border="0" cellspacing="0" cellpadding="0">
 <tr><td>
  <table border="0" cellspacing="0" cellpadding="3" cellborder="1"><tr>
   <td balign="left">XDRV</td>
  </tr></table>
 </td></tr>
 <tr><td>
  <table border="0" cellspacing="0" cellpadding="3" cellborder="1"><tr>
   <td balign="left">Stepper driver — X / horizontal (Wantai DQ542MA)</td>
   <td balign="left">12-pin</td>
  </tr></table>
 </td></tr>
 <tr><td>
  <table border="0" cellspacing="0" cellpadding="3" cellborder="1">
   <tr>
    <td port="p1l">1</td>
    <td>PUL+</td>
    <td port="p1r">1</td>
   </tr>
   <tr>
    <td port="p2l">2</td>
    <td>PUL-</td>
    <td port="p2r">2</td>
   </tr>
   <tr>
    <td port="p3l">3</td>
    <td>DIR+</td>
    <td port="p3r">3</td>
   </tr>
   <tr>
    <td port="p4l">4</td>
    <td>DIR-</td>
    <td port="p4r">4</td>
   </tr>
   <tr>
    <td port="p5l">5</td>
    <td>ENBL+</td>
    <td port="p5r">5</td>
   </tr>
   <tr>
    <td port="p6l">6</td>
    <td>ENBL-</td>
    <td port="p6r">6</td>
   </tr>
   <tr>
    <td port="p7l">7</td>
    <td>DC+</td>
    <td port="p7r">7</td>
   </tr>
   <tr>
    <td port="p8l">8</td>
    <td>DC-</td>
    <td port="p8r">8</td>
   </tr>
   <tr>
    <td port="p9l">9</td>
    <td>A+</td>
    <td port="p9r">9</td>
   </tr>
   <tr>
    <td port="p10l">10</td>
    <td>A-</td>
    <td port="p10r">10</td>
   </tr>
   <tr>
    <td port="p11l">11</td>
    <td>B+</td>
    <td port="p11r">11</td>
   </tr>
   <tr>
    <td port="p12l">12</td>
    <td>B-</td>
    <td port="p12r">12</td>
   </tr>
  </table>
 </td></tr>
 <tr><td>
  <table border="0" cellspacing="0" cellpadding="3" cellborder="1"><tr>
   <td balign="left">18-50 VDC. Common-cathode signal: Mega D5/D7/D6 drive PUL+/DIR+/ENBL+; PUL-/DIR-/ENBL- jumpered to Mega GND. DIP SW1-8 = ON OFF ON OFF ON OFF OFF ON: 128 microstep (25600 pulse/rev), 1.92 A peak / 1.36 A RMS, SW4 OFF = half current at standstill. EN active-LOW (firmware).</td>
  </tr></table>
 </td></tr>
</table>
> fillcolor="#FFFFFF" shape=box style=filled]
